algoritmo "atividade14"

var
numero1:inteiro
antecessor:inteiro
sucessor: inteiro 

inicio
escreva("digite o numero:")
leia (numero1)
antecessor <- numero1-1
sucessor <-numero1 + 1
escreva1 ("digite o numero para verificar qual e o seu sucessor :" , numero1)
escreva1 ("seu antecessor é: ", antecessor)
escreva ("seu sucessor é: ", sucessor)

fimalgoritmo