algoritmo "atividade12"

var
numero, dobro, tecaparte: real
teste: caractere

inicio
escreval ("digiteo numero inteiro para ver seu dobro e sua terça parte: ")
leia (numero)
dobro<- numero * 2
tecaparte <- numero / 3 
escreval ("o dobro é: ", dobro)
escreva (" a terça parte é : ", tecaparte)



fimalgoritmo